<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ pageTitle or siteData.site.pageTitle }}</title>
  <meta name="description" content="{{ metaDescription or siteData.site.metaDescription }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Libre+Caslon+Text:wght@400;700&family=Source+Serif+4:wght@400;600;700&family=Manrope:wght@500;700;800&display=swap"
    rel="stylesheet"
  >
  <link rel="stylesheet" href="/css/style.css">
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
  {{ content | safe }}
  {% if includeMainScript %}
    <script src="/js/main.js"></script>
  {% endif %}
</body>
</html>
